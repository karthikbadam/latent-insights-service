# LLM provider: "openrouter" (default) or "ollama"
# LLM_PROVIDER=openrouter

# Required for openrouter; auto-set for ollama
LLM_API_KEY=

# Optional — defaults shown
# LLM_BASE_URL=https://openrouter.ai/api/v1
# MODEL_PROFILER=google/gemini-2.5-flash
# MODEL_SCOUT=google/gemini-2.5-flash
# MODEL_COORDINATOR=openai/gpt-oss-20b
# MODEL_WORKER=openai/gpt-oss-20b
# MODEL_WORKER_FALLBACK=openai/gpt-oss-20b
# TEMP_PROFILER=0.0
# TEMP_SCOUT=0.7
# TEMP_COORDINATOR=0.3
# TEMP_WORKER=0.0
# DATA_DIR=data
# PORT=8000
# MAX_THREADS=20
# DEFAULT_SEED_THREADS=5
# MAX_WORKER_RETRIES=3
# QUERY_TIMEOUT=60
# CORS_ORIGINS=*
